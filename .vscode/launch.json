{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev (wails dev)",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "program": "${env:HOME}/go/bin/wails",
      "args": ["dev"],
      "cwd": "${workspaceFolder}",
      "env": {},
      "console": "integratedTerminal"
    },
    {
      "name": "Test: pacote atual",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "args": ["-v"],
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Test: todos",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/...",
      "args": ["-v"],
      "cwd": "${workspaceFolder}"
    }
  ]
}
